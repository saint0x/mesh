{
  "version": 1,
  "name": "failover-readiness-gates",
  "steps": [
    {
      "name": "network scheduler status reports readiness blockers and throughput impact",
      "type": "proc_when",
      "cmd": "cargo",
      "args": [
        "test",
        "-p",
        "control-plane",
        "db::tests::test_network_scheduler_status_exposes_queue_groups_and_kv_residency",
        "--",
        "--nocapture"
      ],
      "exit_code": 0,
      "stdout": "test result: ok.\n",
      "times": 1
    },
    {
      "name": "healthy failover profile turns scheduler readiness green",
      "type": "proc_when",
      "cmd": "cargo",
      "args": [
        "test",
        "-p",
        "control-plane",
        "db::tests::test_scheduler_status_readiness_turns_green_for_healthy_failover_profile",
        "--",
        "--nocapture"
      ],
      "exit_code": 0,
      "stdout": "test result: ok.\n",
      "times": 1
    },
    {
      "name": "serialized decode profile remains blocked despite otherwise healthy failover signals",
      "type": "proc_when",
      "cmd": "cargo",
      "args": [
        "test",
        "-p",
        "control-plane",
        "db::tests::test_scheduler_status_readiness_blocks_serialized_decode_profile",
        "--",
        "--nocapture"
      ],
      "exit_code": 0,
      "stdout": "test result: ok.\n",
      "times": 1
    },
    {
      "name": "active decode can shrink from four workers to three and resume immediately",
      "type": "proc_when",
      "cmd": "cargo",
      "args": [
        "test",
        "-p",
        "control-plane",
        "services::failover::tests::reconcile_failover_state_shrinks_four_worker_decode_ring_to_three_and_resumes_ready",
        "--",
        "--nocapture",
        "--test-threads=1"
      ],
      "exit_code": 0,
      "stdout": "test result: ok.\n",
      "times": 1
    }
  ]
}
