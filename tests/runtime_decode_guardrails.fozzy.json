        "--",
        "--nocapture",
        "--test-threads=1"
      ],
      "exit_code": 0,
      "stdout": "test result: ok.\n",
      "times": 1
    },
    {
      "name": "runtime accounting separates live kv bytes from logical decode footprint",
      "type": "proc_when",
      "cmd": "cargo",
      "args": [
        "test",
        "-p",
        "agent",
        "inference::coordinator::tests::test_runtime_memory_snapshot_separates_live_bytes_from_logical_kv_tokens",
