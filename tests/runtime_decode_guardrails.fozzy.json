{
  "version": 1,
  "name": "runtime-decode-guardrails",
  "steps": [
    {
      "name": "throughput decode batching defers mixed-provider sessions instead of silently serializing",
      "type": "proc_when",
      "cmd": "cargo",
      "args": [
        "test",
        "-p",
        "agent",
        "inference::coordinator::tests::test_throughput_batch_guardrail_defers_mixed_provider_sessions",
        "--",
        "--nocapture",
        "--test-threads=1"
      ],
      "exit_code": 0,
      "stdout": "test result: ok.\n",
      "times": 1
    },
    {
      "name": "fit-first batching keeps mixed-provider admission available",
